# Copy outside the repository, set restrictive permissions, and replace every value.
API_IMAGE=ghcr.io/your-org/ahinarena-api@sha256:REPLACE_ME
WORKER_IMAGE=ghcr.io/your-org/ahinarena-worker@sha256:REPLACE_ME
BOT_SANDBOX_IMAGE=ghcr.io/your-org/ahinarena-bot-runner@sha256:REPLACE_ME

POSTGRES_DB=ahin_arena
POSTGRES_USER=ahin_arena
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_SECRET
# URL-encode special characters in the password here.
DATABASE_URL=postgresql+psycopg://ahin_arena:REPLACE_WITH_URL_ENCODED_PASSWORD@postgres:5432/ahin_arena

CORS_ALLOWED_ORIGINS=https://arena.example.com
FRONTEND_URL=https://arena.example.com
AHINARENA_DOMAIN=arena.example.com
RESEND_API_KEY=REPLACE_WITH_SECRET_MANAGER_REFERENCE
EMAIL_FROM="AhinArena <noreply@arena.example.com>"
WORKER_POLL_INTERVAL_SECONDS=5
BOT_MOVE_TIMEOUT_SECONDS=10.0
BOT_STARTUP_TIMEOUT_SECONDS=10.0
DOCKER_BINARY=docker
DEFAULT_BOT_EXECUTABLE_DIR=/app/default-bots
# Dedicated host directory, writable only by the worker's host identity. It is
# bind-mounted at the same absolute path so Docker can mount each bot read-only.
BOT_SANDBOX_HOST_DIR=/var/lib/ahinarena/bot-sandbox
BOT_SANDBOX_MEMORY_LIMIT=128m
BOT_SANDBOX_CPU_LIMIT=0.5
BOT_SANDBOX_PIDS_LIMIT=64
BOT_SANDBOX_TMPFS_SIZE=16m
# Linux only: stat -c '%g' /var/run/docker.sock
DOCKER_SOCKET_GID=999
# The reverse proxy must attach to this network.
INGRESS_NETWORK=ahinarena-ingress
