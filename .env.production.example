# Production configuration template. Store real values in a secret manager or
# a host-owned env file outside the repository; never commit a populated copy.
DEPLOY_ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://ahin_arena:URL_ENCODED_DATABASE_PASSWORD@postgres:5432/ahin_arena
CORS_ALLOWED_ORIGINS=https://arena.example.com
FRONTEND_URL=https://arena.example.com
REQUIRE_SECURE_COOKIES=true

# Required for verification and password-reset email.
RESEND_API_KEY=REPLACE_WITH_SECRET_MANAGER_REFERENCE
EMAIL_FROM="AhinArena <noreply@arena.example.com>"
EMAIL_DELIVERY_TIMEOUT_SECONDS=10

# Required by workers. Pin the sandbox image to an immutable digest.
BOT_SANDBOX_IMAGE=ghcr.io/your-org/ahinarena-bot-runner@sha256:REPLACE_ME
DOCKER_BINARY=docker
BOT_SANDBOX_MEMORY_LIMIT=128m
BOT_SANDBOX_CPU_LIMIT=0.5
BOT_SANDBOX_PIDS_LIMIT=64
BOT_SANDBOX_TMPFS_SIZE=16m
BOT_MOVE_TIMEOUT_SECONDS=2
BOT_STARTUP_TIMEOUT_SECONDS=10

# Optional tuning.
MAX_BOT_EXECUTABLE_BYTES=10485760
MAX_BOTS_PER_USER=25
MAX_ACTIVE_MATCH_JOBS_PER_USER=10
WORKER_POLL_INTERVAL_SECONDS=5
MATCH_JOB_STALL_TIMEOUT_SECONDS=30
MATCH_JOB_MAX_ATTEMPTS=3

# Additional deploy/compose.production.yaml inputs.
API_IMAGE=ghcr.io/your-org/ahinarena-api@sha256:REPLACE_ME
WORKER_IMAGE=ghcr.io/your-org/ahinarena-worker@sha256:REPLACE_ME
POSTGRES_DB=ahin_arena
POSTGRES_USER=ahin_arena
POSTGRES_PASSWORD=REPLACE_WITH_SECRET_MANAGER_REFERENCE
DOCKER_SOCKET_GID=999
INGRESS_NETWORK=ahinarena-ingress
